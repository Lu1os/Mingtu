<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:background="#000000"
              android:orientation="vertical">

    <!-- 顶部栏 -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="20dp">

        <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:contentDescription="返回"
                android:src="@drawable/ic_back" />

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="系统设置"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />
    </LinearLayout>

    <!-- 设置项列表（可滚动） -->
    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="24dp"
            android:paddingBottom="32dp">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:showDividers="middle"
                android:dividerPadding="8dp">

            <!-- ========== 语音反馈 ========== -->
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp"
                    android:text="语音反馈"
                    android:textColor="#60A5FA"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

            <!-- 播报音色 -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_panel"
                    android:orientation="vertical"
                    android:padding="20dp">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="播报音色"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="选择语音播报的发音人"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp" />

                <RadioGroup
                        android:id="@+id/rg_voice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                    <RadioButton
                            android:id="@+id/rb_xiaoyan"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_voice_option"
                            android:button="@null"
                            android:drawableEnd="@drawable/ic_check"
                            android:drawablePadding="8dp"
                            android:padding="16dp"
                            android:text="小燕 (知性女声)"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp" />

                    <RadioButton
                            android:id="@+id/rb_xiaofeng"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_voice_option"
                            android:button="@null"
                            android:drawableEnd="@drawable/ic_check"
                            android:drawablePadding="8dp"
                            android:padding="16dp"
                            android:text="小峰 (商务男声)"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp" />
                </RadioGroup>

                <!-- 试听按钮 -->
                <Button
                        android:id="@+id/btn_preview_voice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_blue_button"
                        android:text="试听当前音色"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:padding="14dp" />
            </LinearLayout>

            <!-- 语速调节 -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_glass_panel"
                    android:orientation="vertical"
                    android:padding="20dp">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                    <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="语速调节"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />

                    <TextView
                            android:id="@+id/tv_speed_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="正常"
                            android:textColor="#60A5FA"
                            android:textSize="14sp" />
                </LinearLayout>

                <SeekBar
                        android:id="@+id/seekbar_speed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:max="100"
                        android:progress="50"
                        android:progressTint="#3B82F6"
                        android:thumbTint="#FFFFFF" />
            </LinearLayout>

            <!-- 音量调节 -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_glass_panel"
                    android:orientation="vertical"
                    android:padding="20dp">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                    <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="音量调节"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />

                    <TextView
                            android:id="@+id/tv_volume_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="50%"
                            android:textColor="#60A5FA"
                            android:textSize="14sp" />
                </LinearLayout>

                <SeekBar
                        android:id="@+id/seekbar_volume"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:max="100"
                        android:progress="50"
                        android:progressTint="#3B82F6"
                        android:thumbTint="#FFFFFF" />
            </LinearLayout>

            <!-- ========== 唤醒设置 ========== -->
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:layout_marginBottom="12dp"
                    android:text="语音唤醒"
                    android:textColor="#60A5FA"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

            <!-- 唤醒灵敏度 -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_panel"
                    android:orientation="vertical"
                    android:padding="20dp">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                    <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="唤醒灵敏度"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />

                    <TextView
                            android:id="@+id/tv_threshold_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="正常"
                            android:textColor="#60A5FA"
                            android:textSize="14sp" />
                </LinearLayout>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="灵敏度越高越容易误触发，越低则需要更清晰地说出唤醒词"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp" />

                <SeekBar
                        android:id="@+id/seekbar_threshold"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:max="100"
                        android:progress="50"
                        android:progressTint="#3B82F6"
                        android:thumbTint="#FFFFFF" />
            </LinearLayout>

            <!-- ========== 其他设置 ========== -->
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:layout_marginBottom="12dp"
                    android:text="其他"
                    android:textColor="#60A5FA"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

            <!-- 服务器 IP 地址 -->
            <LinearLayout
                    android:id="@+id/layout_server_ip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_glass_panel"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:clickable="true"
                    android:focusable="true">

                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="服务器 IP 地址"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />

                    <TextView
                            android:id="@+id/tv_server_ip_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="10.156.170.136"
                            android:textColor="#9CA3AF"
                            android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="修改" />
            </LinearLayout>

            <!-- 控制键手柄 -->
            <LinearLayout
                    android:id="@+id/layout_key_handler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_panel"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="控制键手柄"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="开启后可用音量键替代触摸屏操作"
                            android:textColor="#9CA3AF"
                            android:textSize="12sp" />
                </LinearLayout>

                <Switch
                        android:id="@+id/switch_key_handler"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="#FFFFFF"
                        android:trackTint="#3B82F6" />
            </LinearLayout>

            <!-- 触感反馈 -->
            <LinearLayout
                    android:id="@+id/layout_haptic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_glass_panel"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="触感反馈"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="操作时震动反馈"
                            android:textColor="#9CA3AF"
                            android:textSize="12sp" />
                </LinearLayout>

                <Switch
                        android:id="@+id/switch_haptic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="#FFFFFF"
                        android:trackTint="#3B82F6" />
            </LinearLayout>

            <!-- 帮助中心 -->
            <LinearLayout
                    android:id="@+id/layout_help"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_glass_panel"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="帮助中心"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="使用指南与常见问题"
                            android:textColor="#9CA3AF"
                            android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="进入" />
            </LinearLayout>

            <!-- 版本信息 -->
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="16dp"
                    android:text="明途 Mingtu v0.1.0"
                    android:textColor="#4B5563"
                    android:textSize="12sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
